{
  "name": "@ashios15/react-a11y-audit",
  "version": "2.0.0",
  "description": "React a11y audit toolkit — live dev overlay + CI baseline-diff ratchet. Fail the build only on new WCAG violations, not the existing backlog.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./baseline": {
      "types": "./dist/baseline.d.ts",
      "import": "./dist/baseline.js",
      "require": "./dist/baseline.cjs"
    }
  },
  "bin": {
    "a11y-baseline": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "axe-core": "^4.10.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "react",
    "accessibility",
    "a11y",
    "wcag",
    "wcag-2.2",
    "axe",
    "axe-core",
    "audit",
    "ci",
    "baseline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ashios15/react-a11y-audit.git"
  },
  "bugs": {
    "url": "https://github.com/ashios15/react-a11y-audit/issues"
  },
  "homepage": "https://github.com/ashios15/react-a11y-audit#readme",
  "author": "ashios15",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
